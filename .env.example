# ==============================================
# TELEGRAM BOT CONFIGURATION
# ==============================================
# Token obtenido de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# ==============================================
# OLLAMA LLM CONFIGURATION
# ==============================================
# Nombre del modelo a usar (debe estar descargado en Ollama)
OLLAMA_MODEL=qwen3:1.7b

# Timeout para generación (en segundos)
OLLAMA_TIMEOUT=45

# ==============================================
# GOOGLE SHEETS CONFIGURATION
# ==============================================
# Ruta al archivo JSON de credenciales de service account
GOOGLE_CREDENTIALS_PATH=/home/pi/.credentials/google_sheets.json

# ID del spreadsheet (extraído de la URL)
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
SPREADSHEET_ID=

# Nombre de la pestaña donde se registrarán los gastos
SHEET_NAME=Gastos

# ==============================================
# CATEGORÍAS PERMITIDAS
# ==============================================
# Lista de categorías válidas separadas por coma
EXPENSE_CATEGORIES=Supermercado,Salidas,Juntadas,Suplementos,Compras

# ==============================================
# LOGGING CONFIGURATION
# ==============================================
# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
